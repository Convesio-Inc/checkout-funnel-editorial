# ConvesioPay credentials (set these as Worker secrets in production)
CPAY_API_KEY=
CPAY_SECRET=
CPAY_INTEGRATION=

# Upstream environment: "test" (sandbox) or "live"
CPAY_ENVIRONMENT=test

# Optional. When set, a successful payment POSTs an `order.created` event to
# this Store Manager campaign webhook. Leave unset to skip the notification.
STORE_MANAGER_CAMPAIGN_URL=
